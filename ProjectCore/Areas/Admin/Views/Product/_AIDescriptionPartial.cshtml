@* Injected into the existing Product/Upsert.cshtml admin page *@

<div class="card mt-4 border-primary">
    <div class="card-header bg-primary text-white">
        <i class="bi bi-robot"></i> AI Description Generator
    </div>
    <div class="card-body">

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Tone</label>
                <select id="toneSelect" class="form-select">
                    <option value="Professional">Professional</option>
                    <option value="Casual">Casual</option>
                    <option value="Playful">Playful</option>
                    <option value="Academic">Academic</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button id="btnGenerate"
                        type="button"
                        class="btn btn-primary w-100"
                        onclick="generateDescription()">
                    Generate
                </button>
            </div>
        </div>

        <!-- Result area -->
        <div id="aiResult" class="mt-3 d-none">
            <div class="alert alert-success">
                <small id="aiMeta" class="text-muted d-block mb-1"></small>
                <span id="aiText"></span>
            </div>
            <button type="button"
                    class="btn btn-sm btn-outline-success"
                    onclick="applyDescription()">
                Use this description
            </button>
        </div>

        <div id="aiError" class="mt-3 d-none alert alert-danger"></div>
        <div id="aiSpinner" class="mt-3 d-none">
            <div class="spinner-border spinner-border-sm text-primary"></div>
            <span class="ms-2 text-muted">Generating...</span>
        </div>
    </div>
</div>

<script>
    async function generateDescription() {
        const btn     = document.getElementById('btnGenerate');
        const spinner = document.getElementById('aiSpinner');
        const result  = document.getElementById('aiResult');
        const errDiv  = document.getElementById('aiError');

        const name = document.getElementById('Product_Title')?.value;

        // FIX 1: asp-for="@Model.Product.CategoryId" renders as id="Product_CategoryId"
        // The original used 'categoryDropdown' which does not exist in your form
        const categorySelect = document.getElementById('Product_CategoryId');
        const category = categorySelect?.options[categorySelect.selectedIndex]?.text;

        const tone = document.getElementById('toneSelect').value;

        if (!name) { alert('Enter a product title first.'); return; }

        btn.disabled = true;
        spinner.classList.remove('d-none');
        result.classList.add('d-none');
        errDiv.classList.add('d-none');

        try {
            const response = await fetch('/AI/GenerateDescription', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productName: name, category, tone })
            });

            if (!response.ok) throw new Error('Service unavailable');

            const data = await response.json();
            document.getElementById('aiText').textContent = data.description;
            document.getElementById('aiMeta').textContent =
                `${data.fromCache ? '⚡ Cached' : '✨ Generated'} · Tone: ${data.tone}`;
            result.classList.remove('d-none');
        } catch (e) {
            errDiv.textContent = 'Failed to generate description. Please try again.';
            errDiv.classList.remove('d-none');
        } finally {
            btn.disabled = false;
            spinner.classList.add('d-none');
        }
    }

    function applyDescription() {
        const text = document.getElementById('aiText').textContent;

        // FIX 2: TinyMCE replaces the textarea with an iframe editor at runtime.
        // Setting textarea.value does nothing visible — must use TinyMCE's own API.
        if (typeof tinymce !== 'undefined' && tinymce.get('Product_Description')) {
            tinymce.get('Product_Description').setContent(text);
        } else {
            // Fallback: if TinyMCE hasn't initialised yet, write to the raw textarea
            const textarea = document.getElementById('Product_Description');
            if (textarea) textarea.value = text;
        }
    }
</script>