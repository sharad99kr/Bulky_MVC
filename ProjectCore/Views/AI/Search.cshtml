@model IEnumerable<Product>

<div class="container">

    @*Search Box*@ 
    <div class="row pt-3 pb-3">
        <div class="col-12">
            <form asp-controller="AI" asp-action="Search" method="get">
                <div class="input-group">
                    <input type="text" name="q" class="form-control form-control-lg"
                           placeholder="Try: cozy mystery, epic fantasy, books for beginners..."
                           value="@ViewBag.SearchQuery" />
                    <button class="btn btn-primary" type="submit">Search</button>
                </div>
            </form>
        </div>
    </div>

    @*Low Confidence Warning*@ 
    @if((bool)(ViewBag.LowConfidence ?? false) && !(bool)(ViewBag.Expanded ?? false)) {
        <a href="/AI/Search?q=@ViewBag.SearchQuery&expand=true"
           class="btn btn-outline-warning mt-2">
            🔍 Results uncertain — Search Harder
        </a>
    }
    @if((bool)(ViewBag.Expanded ?? false)) {
        <small class="text-muted mt-1 d-block">
            Showing expanded search results
        </small>
    }

    @*Results Header*@ 
    @if(ViewBag.SearchQuery != null) {
        <div class="row pb-2">
            <div class="col-12">
                <p class="text-muted">Showing semantic results for "<b>@ViewBag.SearchQuery</b>"</p>
                @* (top score: @ViewBag.TopScore.ToString("F3"), low confidence: @ViewBag.LowConfidence) *@
            </div>
        </div>
    }
    @* Product Grid — identical to Home Index*@ 
    <div class="row pb-3">
        @foreach(var product in Model) {
            <div class="col-lg-3 col-sm-6">
                <div class="row p-2">
                    <div class="col-12 p-1">
                        <div class="card border-0 p-3 shadow border-top border-5 rounded">
                            @if(product.ProductImages != null && product.ProductImages.Count() > 0) {
                                <img src="@product.ProductImages.FirstOrDefault().ImageUrl" class="card-img-top rounded" />
                            } else {
                                <img src="https://placehold.co/500x600/png" class="card-img-top rounded" />
                            }
                            <div class="card-body pb-0">
                                <div class="pl-1">
                                    <p class="card-title h5 text-dark opacity-75 text-uppercase text-center">@product.Title</p>
                                    <p class="card-title text-warning text-center">by <b>@product.Author</b></p>
                                </div>
                                <div class="pl-1">
                                    <p class="text-dark text-opacity-75 text-center">
                                        List Price:
                                        <span class="text-decoration-line-through">
                                            @product.ListPrice.ToString("c")
                                        </span>
                                    </p>
                                </div>
                                <div class="pl-1">
                                    <p class="text-dark text-opacity-75 text-center">
                                        As low as:
                                        <span>
                                            @product.Price100.ToString("c")
                                        </span>
                                    </p>
                                </div>
                            </div>
                            <div>
                                <a asp-action="Details" asp-controller="Home" asp-route-productId="@product.Id"
                                   class="btn btn-primary bg-gradient border-0 form-control">
                                    Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

</div>